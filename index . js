#!/usr/bin/env node

import { GoogleGenerativeAI } from '@google/generative-ai';
import { Command } from 'commander';
import chalk from 'chalk';
import ora from 'ora';
import inquirer from 'inquirer';
import fs from 'fs-extra';
import path from 'path';
import { execSync, spawn } from 'child_process';
import { chromium } from 'playwright';
import { fileURLToPath } from 'url';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const program = new Command();

// ==================== UTILS ====================

const sleep = (ms) => new Promise(r => setTimeout(r, ms));

const extractCodeBlocks = (text, defaultDir = 'src') => {
  const artifacts = [];
  const regex = /File:\s*([^\n]+)\n```(?:\w+)?\n([\s\S]*?)```/g;
  let match;
  while ((match = regex.exec(text)) !== null) {
    artifacts.push({ path: match[1].trim(), content: match[2].trim() });
  }
  if (artifacts.length === 0) {
    const fallback = /```(?:\w+)?\n([\s\S]*?)```/g;
    let count = 0;
    while ((match = fallback.exec(text)) !== null) {
      artifacts.push({ path: `${defaultDir}/file-${count++}.ts`, content: match[1].trim() });
    }
  }
  return artifacts;
};

const writeFiles = async (basePath, artifacts) => {
  for (const a of artifacts) {
    const full = path.join(basePath, a.path);
    await fs.ensureDir(path.dirname(full));
    await fs.writeFile(full, a.content);
  }
};

// ==================== AGENT BASE ====================

class Agent {
  constructor(gemini, name, projectPath) {
    this.model = gemini.getGenerativeModel({ 
      model: 'gemini-1.5-pro-latest',
      generationConfig: { temperature: 0.2, maxOutputTokens: 8192 }
    });
    this.name = name;
    this.projectPath = projectPath;
  }

  async run(prompt, testFn, context) {
    let attempts = 0;
    
    while (true) { // UNLIMITED RETRIES
      attempts++;
      console.log(chalk.gray(`  [${this.name}] Attempt ${attempts}`));
      
      try {
        // Generate
        const result = await this.model.generateContent({
          contents: [{ role: 'user', parts: [{ text: prompt }] }]
        });
        const artifacts = extractCodeBlocks(result.response.text(), this.name);
        await writeFiles(this.projectPath, artifacts);
        
        // Update context
        for (const a of artifacts) context.files[a.path] = a.content;
        
        // Test
        const report = await testFn.call(this);
        
        if (report.passed) {
          console.log(chalk.green(`  ✅ ${this.name} passed (${attempts} attempts)`));
          return true;
        }
        
        console.log(chalk.yellow(`  ⚠️  ${this.name} failed: ${report.error?.substring(0, 100)}...`));
        prompt = `Fix these errors and regenerate ALL files:\n${report.error}\n\nOriginal request:\n${prompt}`;
        await sleep(1000);
        
      } catch (e) {
        console.log(chalk.red(`  ❌ ${this.name} error: ${e.message}`));
        await sleep(2000);
      }
    }
  }
}

// ==================== SPECIALIZED AGENTS ====================

const createAuthAgent = (gemini, projectPath, context) => ({
  name: 'Auth',
  run: async () => {
    const agent = new Agent(gemini, 'Auth', projectPath);
    const prompt = `Create complete NextAuth.js authentication for Next.js 14 with:
1. src/app/api/auth/[...nextauth]/route.ts - NextAuth config with Credentials provider, bcrypt, CSRF
2. src/app/login/page.tsx - Login form with validation
3. src/app/register/page.tsx - Registration form  
4. src/middleware.ts - Protect /dashboard routes
5. src/lib/auth.ts - Helpers
6. prisma/schema.prisma - User model with email, passwordHash

SECURITY: HTTP-only cookies, CSRF tokens, rate limiting, password strength (8+ chars, uppercase, number), no plaintext passwords.

Format:
File: src/app/api/auth/[...nextauth]/route.ts
\`\`\`typescript
// code
\`\`\``;

    return agent.run(prompt, async function() {
      // Write test
      const testCode = `
import { test, expect } from '@playwright/test';
test('resists SQL injection', async ({ page }) => {
  await page.goto('http://localhost:3000/login');
  await page.fill('input[type="email"]', "' OR '1'='1");
  await page.fill('input[type="password"]', "admin");
  await page.click('button[type="submit"]');
  await page.waitForTimeout(500);
  expect(page.url()).toMatch(/login|error/);
});
test('enforces password strength', async ({ page }) => {
  await page.goto('http://localhost:3000/register');
  await page.fill('input[type="email"]', 'test@test.com');
  await page.fill('input[type="password"]', 'weak');
  await page.click('button[type="submit"]');
  const body = await page.textContent('body');
  expect(body).toMatch(/password|strong|8|uppercase/i);
});
`;
      await fs.writeFile(path.join(this.projectPath, 'tests/auth.spec.ts'), testCode);
      
      try {
        execSync('npx playwright install chromium', { cwd: this.projectPath, stdio: 'ignore' });
      } catch(e) {}
      
      try {
        execSync('npx playwright test tests/auth.spec.ts --reporter=line', {
          cwd: this.projectPath, encoding: 'utf-8', timeout: 60000
        });
        return { passed: true };
      } catch(e) {
        return { passed: false, error: e.stdout || e.message };
      }
    }, context);
  }
});

const createDatabaseAgent = (gemini, projectPath, context) => ({
  name: 'Database',
  run: async () => {
    const agent = new Agent(gemini, 'Database', projectPath);
    const prompt = `Create Prisma setup:
1. prisma/schema.prisma - User(id, email, passwordHash, createdAt), Post(id, title, content, authorId, createdAt)
2. src/lib/db.ts - Prisma client singleton
3. .env.example - DATABASE_URL="postgresql://..."

Relations: User has many Posts. Add indexes on email.

Format:
File: prisma/schema.prisma
\`\`\`
// schema
\`\`\``;

    return agent.run(prompt, async function() {
      const hasSchema = await fs.pathExists(path.join(this.projectPath, 'prisma/schema.prisma'));
      return { passed: hasSchema, error: hasSchema ? null : 'Schema not created' };
    }, context);
  }
});

const createUIAgent = (gemini, projectPath, context) => ({
  name: 'UI',
  run: async () => {
    const agent = new Agent(gemini, 'UI', projectPath);
    const prompt = `Create modern React UI with Tailwind:
1. src/app/page.tsx - Landing page with hero, features grid
2. src/app/layout.tsx - Root layout, dark mode support, metadata
3. src/app/globals.css - Tailwind directives, dark mode classes
4. src/components/ui/button.tsx - Reusable button (variants: primary, secondary, danger)
5. tailwind.config.ts - Dark mode 'class', custom colors

Use TypeScript, 'use client' where needed, responsive (mobile-first), accessible (aria-labels).

Format:
File: src/app/page.tsx
\`\`\`tsx
// code
\`\`\``;

    return agent.run(prompt, async function() {
      // Start dev server
      const server = spawn('npm', ['run', 'dev'], { 
        cwd: this.projectPath, detached: true, stdio: 'pipe' 
      });
      
      await sleep(8000);
      let browser;
      
      try {
        browser = await chromium.launch({ headless: true });
        const page = await browser.newPage();
        await page.goto('http://localhost:3000');
        await sleep(2000);
        
        const hasContent = await page.evaluate(() => document.body.innerText.length > 100);
        const title = await page.title();
        
        await browser.close();
        try { process.kill(-server.pid); } catch(e) {}
        
        return { 
          passed: hasContent, 
          error: hasContent ? null : `Page blank or error. Title: ${title}` 
        };
      } catch(e) {
        if (browser) await browser.close();
        try { process.kill(-server.pid); } catch(e) {}
        return { passed: false, error: e.message };
      }
    }, context);
  }
});

// ==================== CLI COMMANDS ====================

program
  .name('ai-builder')
  .description('AI Website Builder - One File Edition')
  .version('1.0.0');

program
  .command('create <name>')
  .description('Create new project')
  .action(async (name) => {
    const { description, apiKey } = await inquirer.prompt([
      { type: 'input', name: 'description', message: 'Describe website:', validate: i => i.length > 5 },
      { type: 'password', name: 'apiKey', message: 'Gemini API Key:', mask: '*' }
    ]);

    const projectPath = path.resolve(name);
    await fs.ensureDir(projectPath);
    
    // Save config
    await fs.writeJson(path.join(projectPath, '.ai-builder.json'), { name, description, apiKey });
    
    // Create minimal Next.js structure
    const pkg = {
      name, version: '0.1.0', private: true, type: 'module',
      scripts: { dev: 'next dev', build: 'next build', test: 'playwright test' },
      dependencies: {
        next: '14.0.0', react: '^18.2.0', 'react-dom': '^18.2.0',
        'next-auth': '^4.24.5', '@auth/prisma-adapter': '^1.0.0',
        '@prisma/client': '^5.6.0', prisma: '^5.6.0',
        bcryptjs: '^2.4.3', 'zod': '^3.22.4',
        tailwindcss: '^3.3.0', postcss: '^8.4.0', autoprefixer: '^10.4.0',
        'class-variance-authority': '^0.7.0', clsx: '^2.0.0', 'tailwind-merge': '^2.0.0'
      },
      devDependencies: {
        typescript: '^5.3.0', '@types/node': '^20.0.0', '@types/react': '^18.2.0',
        '@types/bcryptjs': '^2.4.6', '@playwright/test': '^1.40.0'
      }
    };
    
    await fs.writeFile(path.join(projectPath, 'package.json'), JSON.stringify(pkg, null, 2));
    await fs.writeFile(path.join(projectPath, 'next.config.js'), `/** @type {import('next').NextConfig} */\nmodule.exports = { reactStrictMode: true }`);
    await fs.writeFile(path.join(projectPath, 'tsconfig.json'), JSON.stringify({
      compilerOptions: {
        lib: ["dom", "dom.iterable", "esnext"], allowJs: true, skipLibCheck: true, strict: true,
        noEmit: true, esModuleInterop: true, module: "esnext", moduleResolution: "bundler",
        resolveJsonModule: true, isolatedModules: true, jsx: "preserve", incremental: true,
        plugins: [{ name: "next" }], paths: { "@/*": ["./src/*"] }
      },
      include: ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
      exclude: ["node_modules"]
    }, null, 2));
    
    await fs.ensureDir(path.join(projectPath, 'src/app'));
    await fs.ensureDir(path.join(projectPath, 'tests'));
    
    console.log(chalk.green(`\n✅ Created ${name}`));
    console.log(chalk.blue(`\nNext: cd ${name} && npm install && npx ai-builder build`));
  });

program
  .command('build')
  .description('Build with AI agents')
  .action(async () => {
    const config = await fs.readJson('.ai-builder.json');
    const gemini = new GoogleGenerativeAI(config.apiKey);
    const context = { files: {} };
    
    console.log(chalk.blue.bold(`\n🔨 Building: ${config.description}\n`));
    
    // Install deps first
    console.log(chalk.gray('Installing dependencies...'));
    try {
      execSync('npm install', { stdio: 'inherit' });
    } catch(e) {
      console.log(chalk.yellow('Install may have warnings, continuing...'));
    }
    
    // Run agents in sequence
    const agents = [
      createAuthAgent(gemini, process.cwd(), context),
      createDatabaseAgent(gemini, process.cwd(), context),
      createUIAgent(gemini, process.cwd(), context)
    ];
    
    for (const agent of agents) {
      console.log(chalk.cyan(`\n[${agent.name}] Starting...`));
      await agent.run();
    }
    
    console.log(chalk.green.bold('\n🎉 Build Complete!'));
    console.log(chalk.white('\nRun: npm run dev'));
    console.log(chalk.gray('     Open http://localhost:3000\n'));
  });

program.parse();
